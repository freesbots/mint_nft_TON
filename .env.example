# Настройки для минта SportBull NFT
# ОБЯЗАТЕЛЬНО: Не коммитить этот файл в git!

# Мнемоника кошелька владельца коллекции (24 слова через пробел)
MNEMONIC=word1 word2 word3 ... word24

# API ключи Pinata (для загрузки метаданных NFT)
PINATA_API_KEY=your_pinata_api_key
PINATA_API_SECRET=your_pinata_api_secret

# API ключ TON Center (mainnet) - получить: https://t.me/tonapibot
TONCENTER_API_KEY=your_toncenter_api_key
